{
  "name": "csstruth",
  "version": "0.1.0",
  "description": "Hard ground truth for CSS — extracts the browser's rendered layout as deterministic, diffable text so coding agents stop guessing. MCP server + CLI.",
  "keywords": [
    "css",
    "layout",
    "mcp",
    "model-context-protocol",
    "chrome-devtools-protocol",
    "ai-agents",
    "claude-code",
    "visual-testing",
    "layout-testing",
    "responsive"
  ],
  "license": "MIT",
  "author": "Ikraam Ghoor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikraamg/csstruth.git"
  },
  "homepage": "https://github.com/ikraamg/csstruth#readme",
  "bugs": "https://github.com/ikraamg/csstruth/issues",
  "type": "module",
  "engines": { "node": ">=20" },
  "bin": { "csstruth": "./dist/cli.js" },
  "files": ["dist", "skills", "README.md", "LICENSE"],
  "scripts": {
    "prepublishOnly": "npm run typecheck && npm run build",
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
